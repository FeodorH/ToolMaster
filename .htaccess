RewriteEngine On

# Если запрос к существующему файлу или папке - отдаем его
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Все остальные запросы направляем на index.php
RewriteRule ^(.*)$ index.php [QSA,L]

# Защита JSON файлов
<FilesMatch "\.json$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
